# ─── Core Gateway — Required Environment Variables ───────────────────────────
# Copy this file to .env and replace all placeholder values.
# The server will refuse to start in production if DATABASE_URL,
# JWT_ACCESS_SECRET, or JWT_REFRESH_SECRET are missing.
#
# Generate secrets with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"

# ── Database (REQUIRED) ───────────────────────────────────────────────────────
DATABASE_URL="postgresql://postgres:CHANGE_ME@localhost:5432/takathon?schema=public"

# ── JWT Secrets (REQUIRED) ───────────────────────────────────────────────────
JWT_ACCESS_SECRET=replace_with_strong_random_min_32_chars
JWT_REFRESH_SECRET=replace_with_different_strong_random_min_32_chars

# ── Token TTL ─────────────────────────────────────────────────────────────────
ACCESS_TTL=15m
REFRESH_TTL=7d

# ── Cookie Security ───────────────────────────────────────────────────────────
# Set to "true" in production (requires HTTPS)
COOKIE_SECURE=false

# ── Server ────────────────────────────────────────────────────────────────────
PORT=8000
NODE_ENV=development

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins. Omit in dev to allow localhost:3000-3003.
CORS_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:3002,http://localhost:3003
