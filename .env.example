# =============================================================================
# TAkathon — Production Environment Variables Template
# =============================================================================
#
# USAGE
# -----
# 1. Copy this file:     cp .env.example .env.production
# 2. Fill in all values  (never commit the real .env.production to git)
# 3. On your server:     docker compose -f docker-compose.yml -f docker-compose.prod.yml up -d
#
# ENVIRONMENT SEPARATION
# ----------------------
# Use a separate .env file per environment:
#   .env                    → local development (ignored by git)
#   .env.staging            → staging server (ignored by git — add below)
#   .env.production         → production server (ignored by git — add below)
#
# None of these files should ever be committed. Only this .env.example
# (with placeholder values) is safe to commit.
# =============================================================================


# ---------------------------------------------------------------------------
# Database
# ---------------------------------------------------------------------------
# Use a managed PostgreSQL instance in production (Render, Supabase, Neon, DigitalOcean).
# Append ?sslmode=require for cloud databases.
# Staging and production must have DIFFERENT databases. Never share them.
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DBNAME?sslmode=require

# ---------------------------------------------------------------------------
# JWT Secrets  (generate with: node -e "console.log(require('crypto').randomBytes(48).toString('base64'))")
# At least 32 chars. Must differ between access and refresh. Rotate on suspected compromise.
# ---------------------------------------------------------------------------
JWT_ACCESS_SECRET=REPLACE_WITH_STRONG_RANDOM_SECRET_MIN_32_CHARS
JWT_REFRESH_SECRET=REPLACE_WITH_DIFFERENT_STRONG_RANDOM_SECRET_MIN_32_CHARS

# Token lifetimes (seconds)
ACCESS_TTL=900        # 15 minutes
REFRESH_TTL=604800    # 7 days

# ---------------------------------------------------------------------------
# Server
# ---------------------------------------------------------------------------
NODE_ENV=production
PORT=8000

# Comma-separated list of allowed browser origins.
# Must include all deployed frontend domains (no trailing slash).
CORS_ORIGINS=https://app.yourdomain.com,https://organizer.yourdomain.com,https://sponsor.yourdomain.com

# Internal AI engine URL (use service name within Docker network)
AI_ENGINE_URL=http://ai-engine:8001

# ---------------------------------------------------------------------------
# Frontend (Next.js — must be NEXT_PUBLIC_ to be available in browser bundle)
# ---------------------------------------------------------------------------
# The public-facing URL of the Core Gateway. NO trailing slash, NO /api/v1 suffix.
NEXT_PUBLIC_GATEWAY_URL=https://api.yourdomain.com

# ---------------------------------------------------------------------------
# Sentry (optional — leave blank to disable; errors will NOT be reported)
# ---------------------------------------------------------------------------
# Create a free account at https://sentry.io → create a project per service.
# Copy the DSN from Settings → Projects → <project> → Client Keys (DSN).

# Express gateway DSN  (server-side only — never exposed to browser)
SENTRY_DSN=https://7c44a3b58b32cb6be8ccd472de537884@o4510981856296960.ingest.de.sentry.io/4510981862260816

# Next.js frontends DSN (NEXT_PUBLIC_ = available in browser bundle)
# You can use one project for all frontends, or separate per app.
NEXT_PUBLIC_SENTRY_DSN=https://7c44a3b58b32cb6be8ccd472de537884@o4510981856296960.ingest.de.sentry.io/4510981862260816

# Used to tag releases in Sentry for source-map unwinding.
# Typically set by your CI/CD pipeline (e.g. SENTRY_RELEASE=$GIT_SHA).
SENTRY_RELEASE=

# Required by Sentry CLI for source-map upload during `next build`:
SENTRY_AUTH_TOKEN=     # Settings → Auth Tokens → Create new integration token
SENTRY_ORG=personal-94z
SENTRY_PROJECT=takathon

# ---------------------------------------------------------------------------
# PostgreSQL container (only relevant when running postgres in Docker)
# Production should use a managed DB instead of a Docker postgres container.
# ---------------------------------------------------------------------------
POSTGRES_DB=takathon
POSTGRES_USER=postgres
POSTGRES_PASSWORD=REPLACE_WITH_STRONG_POSTGRES_PASSWORD
